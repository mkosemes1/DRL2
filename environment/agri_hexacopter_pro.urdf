<?xml version="1.0"?>
<robot name="agri_hexacopter_pro">

  <!-- ==================================================================
       MATÉRIAUX
  =================================================================== -->
  <material name="dark_grey"><color rgba="0.2 0.2 0.2 1"/></material>
  <material name="white"><color rgba="1.0 1.0 1.0 1"/></material>
  <material name="red"><color rgba="0.8 0.0 0.0 1"/></material>
  <material name="sensor_blue"><color rgba="0.0 0.5 0.8 1"/></material>
  <material name="tank_green"><color rgba="0.0 0.6 0.2 0.8"/></material>

  <!-- ==================================================================
       CORPS CENTRAL (structure sèche, sans la cuve)
       Masse choisie = 10 kg (structure) + 5 kg (cuve pleine, cf payload)
       => masse totale nominale = 15 kg, cohérente avec le cahier des charges
       Inertie calculée pour un cylindre plein :
         Ixx = Iyy = (1/12) * m * (3r² + h²)
         Izz = (1/2) * m * r²
  =================================================================== -->
  <link name="base_link">
    <inertial>
      <mass value="10.0"/>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <inertia ixx="0.1683" ixy="0" ixz="0" iyy="0.1683" iyz="0" izz="0.3125"/>
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry><cylinder radius="0.25" length="0.12"/></geometry>
      <material name="dark_grey"/>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry><cylinder radius="0.25" length="0.12"/></geometry>
    </collision>
  </link>

  <!-- ==================================================================
       CHARGE UTILE AGRICOLE (cuve de pulvérisation)
       Masse RÉELLE cette fois (5 kg = cuve pleine).
       C'est ce lien qui sera utilisé pour le Domain Randomization
       (masse variable entre 0 kg = cuve vide et 5 kg = cuve pleine)
       via un paramètre exposé dans physics/drone_dynamics.py
       Inertie calculée pour une boîte pleine :
         Ixx = (1/12) m (b²+c²) ; Iyy = (1/12) m (a²+c²) ; Izz = (1/12) m (a²+b²)
       (approximation : décalage du centre de masse en z négligé par simplicité)
  =================================================================== -->
  <link name="agri_payload">
    <inertial>
      <mass value="5.0"/>
      <origin xyz="0 0 0.05" rpy="0 0 0"/>
      <inertia ixx="0.03367" ixy="0" ixz="0" iyy="0.03367" iyz="0" izz="0.04033"/>
    </inertial>
    <visual>
      <origin xyz="0 0 0.05" rpy="0 0 0"/>
      <geometry><box size="0.22 0.22 0.18"/></geometry>
      <material name="tank_green"/>
    </visual>
    <visual>
      <origin xyz="0 0 -0.1" rpy="0 0 0"/>
      <geometry><cylinder radius="0.04" length="0.03"/></geometry>
      <material name="dark_grey"/>
    </visual>
    <visual>
      <origin xyz="0.1 0 -0.07" rpy="0 0 0"/>
      <geometry><box size="0.05 0.05 0.03"/></geometry>
      <material name="sensor_blue"/>
    </visual>
    <collision>
      <origin xyz="0 0 0.05" rpy="0 0 0"/>
      <geometry><box size="0.22 0.22 0.18"/></geometry>
    </collision>
  </link>
  <joint name="joint_payload" type="fixed">
    <parent link="base_link"/>
    <child link="agri_payload"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
  </joint>

  <!-- ==================================================================
       TRAIN D'ATTERRISSAGE — masse faible mais non nulle (0.15 kg / skid)
  =================================================================== -->
  <link name="landing_gear">
    <inertial>
      <mass value="0.3"/>
      <origin xyz="0 0 -0.25" rpy="0 0 0"/>
      <inertia ixx="0.0015" ixy="0" ixz="0" iyy="0.009" iyz="0" izz="0.0105"/>
    </inertial>
    <visual>
      <origin xyz="0 0.2 -0.25" rpy="0 0 0"/>
      <geometry><box size="0.6 0.05 0.03"/></geometry>
      <material name="dark_grey"/>
    </visual>
    <visual>
      <origin xyz="0 -0.2 -0.25" rpy="0 0 0"/>
      <geometry><box size="0.6 0.05 0.03"/></geometry>
      <material name="dark_grey"/>
    </visual>
    <collision>
      <origin xyz="0 0.2 -0.25" rpy="0 0 0"/>
      <geometry><box size="0.6 0.05 0.03"/></geometry>
    </collision>
    <collision>
      <origin xyz="0 -0.2 -0.25" rpy="0 0 0"/>
      <geometry><box size="0.6 0.05 0.03"/></geometry>
    </collision>
  </link>
  <joint name="joint_gear" type="fixed">
    <parent link="base_link"/>
    <child link="landing_gear"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
  </joint>

  <!-- ==================================================================
       BRAS — purement visuels, masse répartie faible et réaliste
  =================================================================== -->
  <link name="arms_visual">
    <inertial>
      <mass value="0.6"/>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <inertia ixx="0.001" ixy="0" ixz="0" iyy="0.05" iyz="0" izz="0.05"/>
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry><box size="1.1 0.04 0.03"/></geometry>
      <material name="dark_grey"/>
    </visual>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 1.047"/>
      <geometry><box size="1.1 0.04 0.03"/></geometry>
      <material name="dark_grey"/>
    </visual>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 -1.047"/>
      <geometry><box size="1.1 0.04 0.03"/></geometry>
      <material name="dark_grey"/>
    </visual>
  </link>
  <joint name="joint_arms" type="fixed">
    <parent link="base_link"/>
    <child link="arms_visual"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
  </joint>

  <!-- ==================================================================
       HÉLICES — masse faible (0.01 kg) + inertie de disque mince
         Izz = 0.5 * m * r²   |   Ixx = Iyy = 0.25 * m * r²
       Un léger amortissement est ajouté sur l'axe pour la stabilité
       numérique dans Bullet.
  =================================================================== -->
  <link name="prop_1"><inertial><mass value="0.01"/><origin xyz="0 0 0"/><inertia ixx="0.00008" ixy="0" ixz="0" iyy="0.00008" iyz="0" izz="0.00016"/></inertial>
    <visual><geometry><cylinder radius="0.18" length="0.01"/></geometry><material name="red"/></visual></link>
  <link name="prop_2"><inertial><mass value="0.01"/><origin xyz="0 0 0"/><inertia ixx="0.00008" ixy="0" ixz="0" iyy="0.00008" iyz="0" izz="0.00016"/></inertial>
    <visual><geometry><cylinder radius="0.18" length="0.01"/></geometry><material name="red"/></visual></link>
  <link name="prop_3"><inertial><mass value="0.01"/><origin xyz="0 0 0"/><inertia ixx="0.00008" ixy="0" ixz="0" iyy="0.00008" iyz="0" izz="0.00016"/></inertial>
    <visual><geometry><cylinder radius="0.18" length="0.01"/></geometry><material name="red"/></visual></link>
  <link name="prop_4"><inertial><mass value="0.01"/><origin xyz="0 0 0"/><inertia ixx="0.00008" ixy="0" ixz="0" iyy="0.00008" iyz="0" izz="0.00016"/></inertial>
    <visual><geometry><cylinder radius="0.18" length="0.01"/></geometry><material name="red"/></visual></link>
  <link name="prop_5"><inertial><mass value="0.01"/><origin xyz="0 0 0"/><inertia ixx="0.00008" ixy="0" ixz="0" iyy="0.00008" iyz="0" izz="0.00016"/></inertial>
    <visual><geometry><cylinder radius="0.18" length="0.01"/></geometry><material name="red"/></visual></link>
  <link name="prop_6"><inertial><mass value="0.01"/><origin xyz="0 0 0"/><inertia ixx="0.00008" ixy="0" ixz="0" iyy="0.00008" iyz="0" izz="0.00016"/></inertial>
    <visual><geometry><cylinder radius="0.18" length="0.01"/></geometry><material name="red"/></visual></link>

  <!-- Disposition hexacopter en X, cohérente avec les bras (0°,60°,120°,180°,240°,300°) -->
  <joint name="j_p1" type="continuous">
    <parent link="base_link"/><child link="prop_1"/><axis xyz="0 0 1"/>
    <origin xyz="0.55 0 0.06"/><dynamics damping="0.001" friction="0.0"/>
  </joint>
  <joint name="j_p2" type="continuous">
    <parent link="base_link"/><child link="prop_2"/><axis xyz="0 0 1"/>
    <origin xyz="-0.55 0 0.06"/><dynamics damping="0.001" friction="0.0"/>
  </joint>
  <joint name="j_p3" type="continuous">
    <parent link="base_link"/><child link="prop_3"/><axis xyz="0 0 1"/>
    <origin xyz="0.27 0.47 0.06"/><dynamics damping="0.001" friction="0.0"/>
  </joint>
  <joint name="j_p4" type="continuous">
    <parent link="base_link"/><child link="prop_4"/><axis xyz="0 0 1"/>
    <origin xyz="-0.27 -0.47 0.06"/><dynamics damping="0.001" friction="0.0"/>
  </joint>
  <joint name="j_p5" type="continuous">
    <parent link="base_link"/><child link="prop_5"/><axis xyz="0 0 1"/>
    <origin xyz="0.27 -0.47 0.06"/><dynamics damping="0.001" friction="0.0"/>
  </joint>
  <joint name="j_p6" type="continuous">
    <parent link="base_link"/><child link="prop_6"/><axis xyz="0 0 1"/>
    <origin xyz="-0.27 0.47 0.06"/><dynamics damping="0.001" friction="0.0"/>
  </joint>

</robot>